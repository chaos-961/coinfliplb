# PostgreSQL connection string. Railway provides this automatically when you
# attach a PostgreSQL plugin to your service. Example:
# postgresql://user:password@host:port/database
DATABASE_URL=

# A long random string used to sign JWT auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_secret

# Starting gold balance for every new account. Backend is the source
# of truth. The frontend has its own STARTING_BALANCE in config.js but only
# for display — this value is what is actually written to the database.
STARTING_BALANCE=100

# The exact origin of your deployed frontend (no trailing slash).
# In production this should be your GitHub Pages URL, e.g.
#   https://yourusername.github.io
# CORS will only accept requests from this origin (plus localhost in dev).
FRONTEND_ORIGIN=https://yourusername.github.io

# Port the Express server listens on. Railway sets PORT automatically;
# you usually do not need to override this.
PORT=3000
