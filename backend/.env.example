# =====================================================================
# Coinflip Gold backend — v1.1 environment variables
# ---------------------------------------------------------------------
# Copy this to backend/.env for local development. In production
# (Railway) set the same keys via the service's "Variables" panel.
# =====================================================================

# ---- Required in production -----------------------------------------

# PostgreSQL connection string. Railway provides this automatically when
# you attach a PostgreSQL plugin to your service. Example:
#   postgresql://user:password@host:port/database
DATABASE_URL=

# A long random string used to sign JWT auth tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# In production the server REFUSES to boot if this is missing or shorter
# than 16 characters.
JWT_SECRET=replace_this_with_a_long_random_secret

# Comma-separated list of frontend origins allowed by CORS. In
# production the server REFUSES to boot if this is empty.
# Example:
#   FRONTEND_ORIGIN=https://coinfliplb.com,https://www.coinfliplb.com
FRONTEND_ORIGIN=https://coinfliplb.com

# Set to "production" on Railway. Anything else (or unset) is treated
# as development and relaxes the boot-time guards above.
NODE_ENV=production

# ---- Optional / tunable ---------------------------------------------

# Starting gold balance for every new account.
STARTING_BALANCE=100

# Port the Express server listens on. Railway sets PORT automatically;
# you usually do not need to override this.
PORT=3000

# Number of proxy hops to trust for resolving the real client IP.
# Railway sits behind one proxy, hence the default of 1. Increase if
# your stack puts more proxies in front of Node.
TRUST_PROXY=1

# Salt mixed into IP / user-agent SHA-256 hashes so raw IPs are never
# stored. If unset the server falls back to JWT_SECRET. Rotate to
# invalidate stored signup-IP fingerprints.
IP_HASH_SALT=

# Bearer token required by /api/admin/* endpoints. If unset, those
# endpoints return 503 — admin tooling is opt-in.
ADMIN_API_TOKEN=

# Auto-cancel stale open games after this many hours and refund the
# creator. 0 disables the reaper.
OPEN_GAME_TTL_HOURS=48

# Require uppercase + lowercase + digit in passwords. Off by default;
# turn on once your user base accepts it.
REQUIRE_STRONG_PASSWORD=false

# ---- Signup-throttle tuning -----------------------------------------

# Hard caps per IP per 24h, enforced via the signup_attempts table.
SIGNUP_MAX_PER_IP_DAY=20
SIGNUP_MAX_ACCOUNTS_PER_IP_DAY=5

# Soft cooldown between attempts from the same IP (ms).
SIGNUP_COOLDOWN_MS=4000

# Sliding-window cap from express-rate-limit (per IP, per hour).
SIGNUP_MAX_PER_IP_HOUR=10

# ---- Other abuse-control knobs (rarely changed) ---------------------

MAX_IN_FLIGHT_PER_IP=25
CREATE_COOLDOWN_MS=2500
JOIN_COOLDOWN_MS=1800
CANCEL_COOLDOWN_MS=1600
GAMES_CACHE_TTL_MS=1500
LEADERBOARD_CACHE_TTL_MS=5000
ONLINE_WINDOW_MS=90000
